<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TradeSkills — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f5f4;
      --white: #ffffff;
      --border: #e2e2df;
      --text: #1c1c1a;
      --muted: #888884;
      --accent: #2563eb;
      --danger: #dc2626;
      --warn: #d97706;
      --success: #16a34a;
      --radius: 6px;
    }

    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
    }

    a { text-decoration: none; color: inherit; }

    .layout { display: flex; min-height: 100vh; }

    /* SIDEBAR */
    .sidebar {
      width: 200px;
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      padding: 24px 0;
    }

    .logo {
      padding: 0 20px 20px;
      border-bottom: 1px solid var(--border);
      font-weight: 600;
      font-size: 15px;
    }

    .logo span {
      display: block;
      font-size: 10px;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-top: 2px;
    }

    nav { padding: 16px 12px; flex: 1; }

    nav a {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 8px;
      border-radius: var(--radius);
      color: var(--muted);
      font-size: 13.5px;
      transition: background .1s, color .1s;
    }

    nav a:hover { background: var(--bg); color: var(--text); }
    nav a.active { background: var(--bg); color: var(--accent); font-weight: 500; }

    .section-label {
      font-size: 10px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 14px 8px 4px;
      font-weight: 500;
    }

    .badge {
      margin-left: auto;
      background: #fee2e2;
      color: var(--danger);
      font-size: 10px;
      font-weight: 600;
      padding: 1px 6px;
      border-radius: 99px;
    }

    .sidebar-footer {
      padding: 16px 20px 0;
      border-top: 1px solid var(--border);
      font-size: 12.5px;
      color: var(--muted);
    }

    .sidebar-footer strong { display: block; color: var(--text); font-weight: 500; }

    /* MAIN */
    .main { margin-left: 200px; flex: 1; }

    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 0 28px;
      height: 52px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .topbar h1 { font-size: 14px; font-weight: 600; flex: 1; }

    .topbar input {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 6px 12px;
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      outline: none;
      width: 200px;
    }

    .topbar input:focus { border-color: var(--accent); }
    .topbar input::placeholder { color: var(--muted); }

    .content { padding: 28px; display: flex; flex-direction: column; gap: 20px; }

    /* STATS */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

    .stat {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
    }

    .stat-label { font-size: 11px; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: .6px; margin-bottom: 8px; }
    .stat-value { font-family: 'IBM Plex Mono', monospace; font-size: 24px; font-weight: 500; }
    .stat-sub { font-size: 11.5px; color: var(--muted); margin-top: 4px; }
    .stat-sub.up { color: var(--success); }
    .stat-sub.down { color: var(--danger); }

    /* GRID */
    .grid { display: grid; grid-template-columns: 1fr 300px; gap: 16px; }

    /* CARD */
    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .card-head {
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .card-head h2 { font-size: 13px; font-weight: 600; }
    .card-head .sub { font-size: 11.5px; color: var(--muted); }

    /* TABS */
    .tabs { display: flex; border-bottom: 1px solid var(--border); }

    .tab {
      padding: 12px 20px;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color .1s, border-color .1s;
    }

    .tab:hover { color: var(--text); }
    .tab.active { color: var(--accent); border-color: var(--accent); }

    /* TABLE */
    table { width: 100%; border-collapse: collapse; }

    thead th {
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .7px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 10px 20px;
      border-bottom: 1px solid var(--border);
    }

    tbody tr { border-bottom: 1px solid var(--border); transition: background .1s; cursor: pointer; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--bg); }
    tbody td { padding: 12px 20px; font-size: 13px; vertical-align: middle; }

    /* STATUS PILLS */
    .pill {
      display: inline-block;
      font-size: 11px;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: 99px;
    }

    .pill-new { background: #dbeafe; color: #1d4ed8; }
    .pill-ongoing { background: #fef3c7; color: #92400e; }
    .pill-resolved { background: #dcfce7; color: #15803d; }

    /* BUTTONS */
    .btn-row { display: flex; gap: 6px; }

    .btn {
      display: inline-block;
      padding: 5px 12px;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      border: 1px solid var(--border);
      transition: opacity .1s;
      background: var(--bg);
      color: var(--text);
    }

    .btn:hover { opacity: .7; }
    .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
    .btn-danger { background: #fee2e2; color: var(--danger); border-color: #fecaca; }
    .btn-warn { background: #fef3c7; color: var(--warn); border-color: #fde68a; }
    .btn-success { background: #dcfce7; color: var(--success); border-color: #bbf7d0; }

    /* METRICS */
    .metric {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }

    .metric:last-child { border-bottom: none; }
    .metric-label { font-size: 11px; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: .6px; margin-bottom: 6px; }
    .metric-value { font-family: 'IBM Plex Mono', monospace; font-size: 20px; font-weight: 500; }
    .metric-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }

    .quick-actions { display: flex; flex-direction: column; gap: 6px; padding: 14px; }

    /* LOGS */
    .log-row {
      display: grid;
      grid-template-columns: 10px 1fr auto;
      gap: 12px;
      align-items: start;
      padding: 11px 20px;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }

    .log-row:last-child { border-bottom: none; }

    .log-dot { width: 7px; height: 7px; border-radius: 50%; margin-top: 5px; }
    .dot-error { background: var(--danger); }
    .dot-warn { background: var(--warn); }
    .dot-ok { background: var(--success); }
    .dot-info { background: var(--accent); }

    .log-msg small { color: var(--muted); display: block; font-size: 12px; }
    .log-ts { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--muted); white-space: nowrap; margin-top: 3px; }
    .sev { font-size: 11px; }
    .sev-high { color: var(--danger); }
    .sev-med { color: var(--warn); }
    .sev-none { color: var(--muted); }

    /* MODAL */
    .overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.25);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 100;
      padding: 20px;
    }

    .overlay.show { display: flex; }

    .modal {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      width: 100%;
      max-width: 460px;
    }

    .modal-head {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-head h3 { font-size: 14px; font-weight: 600; }
    .close-btn { background: none; border: none; color: var(--muted); font-size: 18px; cursor: pointer; }
    .close-btn:hover { color: var(--text); }

    .modal-body { padding: 20px; display: flex; flex-direction: column; gap: 14px; }

    .field-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); margin-bottom: 4px; }

    .field-value {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 12px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.55;
    }

    .chips { display: flex; gap: 8px; flex-wrap: wrap; }

    .chip {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 4px 10px;
      font-size: 12px;
    }

    .chip b { color: var(--muted); font-weight: 400; margin-right: 4px; }

    .modal-foot {
      padding: 14px 20px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 6px;
      justify-content: flex-end;
    }

    @media (max-width: 900px) {
      .stats { grid-template-columns: 1fr 1fr; }
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<div class="layout">

  <aside class="sidebar">
    <div class="logo">
      TradeSkills
      <span>Admin Portal</span>
    </div>
    <nav>
      <div class="section-label">Main</div>
      <a href="#" class="active">Dashboard</a>

      <div class="section-label">Moderation</div>
      <a href="#" onclick="switchTab('reports');return false">Reports <span class="badge">7</span></a>
      <a href="#" onclick="switchTab('logs');return false">Security Logs</a>

      <div class="section-label">Platform</div>
      <a href="#">Users</a>
      <a href="#">Credits</a>
      <a href="#">Lessons</a>

      <div class="section-label">Account</div>
      <a href="#">Settings</a>
      <a href="#">Log out</a>
    </nav>
    <div class="sidebar-footer">
      <strong>Admin</strong>
      Administrator
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <h1>Dashboard</h1>
      <input type="text" placeholder="Search users, reports…"/>
    </div>

    <div class="content">

      <div class="stats">
        <div class="stat">
          <div class="stat-label">Total Users</div>
          <div class="stat-value">1,284</div>
          <div class="stat-sub up">+32 this week</div>
        </div>
        <div class="stat">
          <div class="stat-label">Credits in Circulation</div>
          <div class="stat-value">48,320</div>
          <div class="stat-sub up">+1,140 this fortnight</div>
        </div>
        <div class="stat">
          <div class="stat-label">Open Reports</div>
          <div class="stat-value">7</div>
          <div class="stat-sub down">+3 since yesterday</div>
        </div>
        <div class="stat">
          <div class="stat-label">Lessons Completed</div>
          <div class="stat-value">3,091</div>
          <div class="stat-sub up">+84 this week</div>
        </div>
      </div>

      <div class="grid">

        <div class="card">
          <div class="tabs">
            <div class="tab active" id="tab-reports" onclick="switchTab('reports')">Reports</div>
            <div class="tab" id="tab-logs" onclick="switchTab('logs')">Security Logs</div>
          </div>

          <div id="view-reports">
            <table>
              <thead>
                <tr>
                  <th>Reporter → Reported</th>
                  <th>Description</th>
                  <th>Status</th>
                  <th>Filed</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <tr onclick="openModal('Inappropriate messaging during lesson session.','jsmith','u_pete99','4 hrs ago','new')">
                  <td>jsmith → u_pete99</td>
                  <td style="color:var(--muted)">Inappropriate messaging during lesson</td>
                  <td><span class="pill pill-new">New</span></td>
                  <td style="color:var(--muted)">4 hrs ago</td>
                  <td><div class="btn-row" onclick="event.stopPropagation()">
                    <button class="btn btn-warn">Ongoing</button>
                    <button class="btn btn-success">Resolve</button>
                  </div></td>
                </tr>
                <tr onclick="openModal('Fake review left — claims lesson never happened.','sarah_k','devguru','9 hrs ago','ongoing')">
                  <td>sarah_k → devguru</td>
                  <td style="color:var(--muted)">Fake review, lesson never happened</td>
                  <td><span class="pill pill-ongoing">Ongoing</span></td>
                  <td style="color:var(--muted)">9 hrs ago</td>
                  <td><div class="btn-row" onclick="event.stopPropagation()">
                    <button class="btn btn-success">Resolve</button>
                  </div></td>
                </tr>
                <tr onclick="openModal('Lesson content did not match the advertised description.','mike_b','skillshare99','1 day ago','new')">
                  <td>mike_b → skillshare99</td>
                  <td style="color:var(--muted)">Lesson didn't match description</td>
                  <td><span class="pill pill-new">New</span></td>
                  <td style="color:var(--muted)">1 day ago</td>
                  <td><div class="btn-row" onclick="event.stopPropagation()">
                    <button class="btn btn-warn">Ongoing</button>
                    <button class="btn btn-success">Resolve</button>
                  </div></td>
                </tr>
                <tr onclick="openModal('Abusive messages sent via chat after lesson was completed.','aiden_x','tutor_pro','2 days ago','new')">
                  <td>aiden_x → tutor_pro</td>
                  <td style="color:var(--muted)">Abusive messages after lesson</td>
                  <td><span class="pill pill-new">New</span></td>
                  <td style="color:var(--muted)">2 days ago</td>
                  <td><div class="btn-row" onclick="event.stopPropagation()">
                    <button class="btn btn-warn">Ongoing</button>
                    <button class="btn btn-success">Resolve</button>
                  </div></td>
                </tr>
              </tbody>
            </table>
          </div>

          <div id="view-logs" style="display:none">
            <div class="log-row">
              <div class="log-dot dot-error"></div>
              <div class="log-msg">Account locked after 5 failed logins<small>user: mark_d@email.com</small></div>
              <div><div class="log-ts">10:42 AM</div><div class="sev sev-high">High</div></div>
            </div>
            <div class="log-row">
              <div class="log-dot dot-ok"></div>
              <div class="log-msg">Admin resolved report #312<small>by: admin@tradeskills.com</small></div>
              <div><div class="log-ts">10:31 AM</div><div class="sev sev-none">None</div></div>
            </div>
            <div class="log-row">
              <div class="log-dot dot-warn"></div>
              <div class="log-msg">Captcha triggered after 3 failed logins<small>user: leo_test</small></div>
              <div><div class="log-ts">10:18 AM</div><div class="sev sev-med">Medium</div></div>
            </div>
            <div class="log-row">
              <div class="log-dot dot-ok"></div>
              <div class="log-msg">Admin deleted account<small>target: spam_bot_44</small></div>
              <div><div class="log-ts">09:55 AM</div><div class="sev sev-high">High</div></div>
            </div>
            <div class="log-row">
              <div class="log-dot dot-info"></div>
              <div class="log-msg">New user registered<small>user: priya.m@uni.ac.uk</small></div>
              <div><div class="log-ts">09:41 AM</div><div class="sev sev-none">None</div></div>
            </div>
            <div class="log-row">
              <div class="log-dot dot-ok"></div>
              <div class="log-msg">Admin removed credits from user<small>target: bad_actor_22 (−3 credits)</small></div>
              <div><div class="log-ts">09:27 AM</div><div class="sev sev-med">Medium</div></div>
            </div>
            <div class="log-row">
              <div class="log-dot dot-error"></div>
              <div class="log-msg">Suspected XSS input blocked<small>endpoint: /profile/bio</small></div>
              <div><div class="log-ts">08:59 AM</div><div class="sev sev-high">High</div></div>
            </div>
            <div class="log-row">
              <div class="log-dot dot-info"></div>
              <div class="log-msg">Fortnightly credit top-up completed<small>847 users credited</small></div>
              <div><div class="log-ts">00:01 AM</div><div class="sev sev-none">None</div></div>
            </div>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:16px;">
          <div class="card">
            <div class="card-head">
              <h2>Credits</h2>
              <span class="sub">Live totals</span>
            </div>
            <div class="metric">
              <div class="metric-label">In Circulation</div>
              <div class="metric-value">48,320</div>
            </div>
            <div class="metric">
              <div class="metric-label">Issued This Fortnight</div>
              <div class="metric-value">1,140</div>
            </div>
            <div class="metric">
              <div class="metric-label">Next Top-Up</div>
              <div class="metric-value" style="font-size:14px;font-family:'IBM Plex Sans',sans-serif;font-weight:600">18 Mar 2026</div>
              <div class="metric-sub">00:00 scheduled</div>
            </div>
          </div>

          <div class="card">
            <div class="card-head"><h2>Quick Actions</h2></div>
            <div class="quick-actions">
              <button class="btn btn-danger" style="width:100%;text-align:left">Ban User Account</button>
              <button class="btn btn-warn" style="width:100%;text-align:left">Remove Credits</button>
              <button class="btn" style="width:100%;text-align:left">Delete Review</button>
              <button class="btn btn-success" style="width:100%;text-align:left">Mark Report Resolved</button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- MODAL -->
<div class="overlay" id="overlay" onclick="closeModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-head">
      <h3 id="modal-title">Report</h3>
      <button class="close-btn" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div>
        <div class="field-label">Report Message</div>
        <div class="field-value" id="modal-desc"></div>
      </div>
      <div>
        <div class="field-label">Details</div>
        <div class="chips" id="modal-chips"></div>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn" onclick="closeModal()">Cancel</button>
      <button class="btn btn-warn">Set Ongoing</button>
      <button class="btn btn-danger">Ban User</button>
      <button class="btn btn-success">Resolve</button>
    </div>
  </div>
</div>

<script>
  const statusMap = { new: 'pill-new', ongoing: 'pill-ongoing', resolved: 'pill-resolved' };

  function switchTab(t) {
    document.getElementById('view-reports').style.display = t === 'reports' ? '' : 'none';
    document.getElementById('view-logs').style.display = t === 'logs' ? '' : 'none';
    document.getElementById('tab-reports').className = 'tab' + (t === 'reports' ? ' active' : '');
    document.getElementById('tab-logs').className = 'tab' + (t === 'logs' ? ' active' : '');
  }

  function openModal(desc, reporter, reported, time, status) {
    document.getElementById('modal-title').textContent = reporter + ' \u2192 ' + reported;
    document.getElementById('modal-desc').textContent = desc;
    document.getElementById('modal-chips').innerHTML =
      `<div class="chip"><b>Reporter</b>${reporter}</div>` +
      `<div class="chip"><b>Reported</b>${reported}</div>` +
      `<div class="chip"><b>Filed</b>${time}</div>` +
      `<div class="chip"><b>Status</b><span class="pill ${statusMap[status]}">${status}</span></div>`;
    document.getElementById('overlay').classList.add('show');
  }

  function closeModal(e) {
    if (!e || e.target === document.getElementById('overlay'))
      document.getElementById('overlay').classList.remove('show');
  }
</script>
</body>
</html>
