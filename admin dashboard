              <div><div class="log-ts">00:01 AM</div><div class="sev sev-none">None</div></div>
            </div>

          </div>
        </div>


        <!-- RIGHT COLUMN: Credits overview + quick action buttons -->
        <div style="display:flex;flex-direction:column;gap:16px;">

          <!-- ── CREDITS CARD ───────────────────────────────────────────────
               Shows total credits in circulation, issued this fortnight,
               and the date of the next scheduled top-up (NFR6, FR8) -->
          <div class="card">
            <div class="card-head">
              <h2>Credits</h2>
              <span class="sub">Live totals</span>
            </div>

            <!-- Total credits held across all accounts right now -->
            <div class="metric">
