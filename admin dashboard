</div>


<!-- ══ REPORT DETAIL MODAL ════════════════════════════════════════════════
     Hidden by default. Opened by clicking any report row in the table.
     Clicking the backdrop (.overlay) or × button closes it.
     Admin can set the report to Ongoing, Ban the user, or Resolve from here. -->
<div class="overlay" id="overlay" onclick="closeModal(event)">
  <div class="modal" onclick="event.stopPropagation()">

    <!-- Title shows "reporter → reported" — filled by openModal() -->
    <div class="modal-head">
      <h3 id="modal-title">Report</h3>
      <button class="close-btn" onclick="closeModal()">✕</button>
    </div>

    <div class="modal-body">
      <!-- The full report message text -->
      <div>
        <div class="field-label">Report Message</div>
        <div class="field-value" id="modal-desc"></div>
      </div>

      <!-- Metadata chips: reporter, reported user, time filed, current status -->
      <div>
        <div class="field-label">Details</div>
        <div class="chips" id="modal-chips"></div>
      </div>
    </div>

    <!-- Action buttons — wire to Flask POST routes in production -->
    <div class="modal-foot">
      <button class="btn"          onclick="closeModal()">Cancel</button>
      <button class="btn btn-warn">Set Ongoing</button>
      <button class="btn btn-danger">Ban User</button>
      <button class="btn btn-success">Resolve</button>
    </div>

  </div>
</div>


<script>
  // Maps report status strings to their corresponding CSS pill classes
  const statusMap = { new: 'pill-new', ongoing: 'pill-ongoing', resolved: 'pill-resolved' };

  /**
   * switchTab(t)
   * Toggles between the Reports table and the Security Logs list.
   * Shows the matching view div and updates the tab's active styling.
   * @param {string} t - 'reports' or 'logs'
   */
  function switchTab(t) {
    document.getElementById('view-reports').style.display = t === 'reports' ? '' : 'none';
    document.getElementById('view-logs').style.display    = t === 'logs'    ? '' : 'none';
    document.getElementById('tab-reports').className = 'tab' + (t === 'reports' ? ' active' : '');
    document.getElementById('tab-logs').className    = 'tab' + (t === 'logs'    ? ' active' : '');
  }

  /**
   * openModal(desc, reporter, reported, time, status)
   * Populates and shows the report detail modal with data from the clicked row.
   * @param {string} desc     - Full report message text
   * @param {string} reporter - Username of user who filed the report
   * @param {string} reported - Username of user being reported
   * @param {string} time     - Human-readable time since filing (e.g. "4 hrs ago")
   * @param {string} status   - 'new', 'ongoing', or 'resolved'
   */
  function openModal(desc, reporter, reported, time, status) {
    // Set modal title to "reporter → reported"
    document.getElementById('modal-title').textContent = reporter + ' \u2192 ' + reported;

    // Populate the report message body
    document.getElementById('modal-desc').textContent = desc;

    // Build metadata chips and inject them into the modal
    document.getElementById('modal-chips').innerHTML =
      `<div class="chip"><b>Reporter</b>${reporter}</div>` +
      `<div class="chip"><b>Reported</b>${reported}</div>` +
      `<div class="chip"><b>Filed</b>${time}</div>` +
      `<div class="chip"><b>Status</b><span class="pill ${statusMap[status]}">${status}</span></div>`;

    // Show the modal overlay
    document.getElementById('overlay').classList.add('show');
  }

  /**
   * closeModal(e)
   * Hides the modal. Called by the × button or by clicking the backdrop.
   * When triggered by a click event, only closes if the click was on the
   * overlay itself (not on the modal panel inside it).
   * @param {Event} [e] - Optional click event
   */
  function closeModal(e) {
    if (!e || e.target === document.getElementById('overlay'))
      document.getElementById('overlay').classList.remove('show');
  }
</script>
</body>
</html>