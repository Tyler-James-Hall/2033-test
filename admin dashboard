<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TradeSkills — Admin</title>

  <!-- Google Fonts: IBM Plex Sans for UI text, IBM Plex Mono for numeric values -->
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>

  <style>
    /* ── RESET ─────────────────────────────────────────────────────────────
       Remove default browser margin/padding and use border-box sizing
       so padding is included within element widths rather than added on top */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── DESIGN TOKENS ──────────────────────────────────────────────────────
       CSS variables used throughout for consistent colour and spacing.
       Changing a value here updates it everywhere on the page. */
    :root {
      --bg: #f5f5f4;       /* Page background — off-white */
      --white: #ffffff;    /* Card / sidebar surface */
      --border: #e2e2df;   /* Subtle divider lines */
      --text: #1c1c1a;     /* Primary text */
      --muted: #888884;    /* Secondary / placeholder text */
      --accent: #2563eb;   /* Blue — active states, primary buttons */
      --danger: #dc2626;   /* Red — destructive actions, errors */
      --warn: #d97706;     /* Amber — warnings, ongoing status */
      --success: #16a34a;  /* Green — resolved states, positive deltas */
      --radius: 6px;       /* Consistent border-radius across all components */
    }

    /* ── BASE TYPOGRAPHY ────────────────────────────────────────────────── */
    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
    }

    /* Strip underline from links and inherit parent colour by default */
    a { text-decoration: none; color: inherit; }

    /* Full-height flex container — sidebar sits alongside main content */
    .layout { display: flex; min-height: 100vh; }


    /* ── SIDEBAR ────────────────────────────────────────────────────────────
       Fixed left-hand navigation panel. Stays in place while main scrolls. */
    .sidebar {
      width: 200px;
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      position: fixed;          /* Pinned so it doesn't scroll away */
      top: 0; left: 0; bottom: 0;
      padding: 24px 0;
    }

    /* App name and portal label at the top of the sidebar */
    .logo {
      padding: 0 20px 20px;
      border-bottom: 1px solid var(--border);
      font-weight: 600;
      font-size: 15px;
    }

    /* "Admin Portal" subtitle below the wordmark */
    .logo span {
      display: block;
      font-size: 10px;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-top: 2px;
    }

    /* Nav takes remaining sidebar height, pushing footer to the bottom */
    nav { padding: 16px 12px; flex: 1; }

    /* Individual nav links */
    nav a {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 8px;
      border-radius: var(--radius);
      color: var(--muted);
      font-size: 13.5px;
      transition: background .1s, color .1s;
    }

    nav a:hover { background: var(--bg); color: var(--text); }

    /* The currently active page link is highlighted in accent blue */
    nav a.active { background: var(--bg); color: var(--accent); font-weight: 500; }

    /* Small uppercase label grouping nav items into sections (e.g. "Main", "Moderation") */
    .section-label {
      font-size: 10px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 14px 8px 4px;
      font-weight: 500;
    }

    /* Red pill badge — shows unread report count next to "Reports" nav link */
    .badge {
      margin-left: auto;
      background: #fee2e2;
      color: var(--danger);
      font-size: 10px;
      font-weight: 600;
      padding: 1px 6px;
      border-radius: 99px;   /* Fully rounded pill shape */
    }

    /* Logged-in admin info at the bottom of the sidebar */
    .sidebar-footer {
      padding: 16px 20px 0;
      border-top: 1px solid var(--border);
      font-size: 12.5px;
      color: var(--muted);
    }

    .sidebar-footer strong { display: block; color: var(--text); font-weight: 500; }


    /* ── MAIN CONTENT AREA ──────────────────────────────────────────────────
       Offset by sidebar width so content doesn't slide under it */
    .main { margin-left: 200px; flex: 1; }

    /* ── TOPBAR ─────────────────────────────────────────────────────────────
       Sticky header bar containing page title and search input */
    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 0 28px;
      height: 52px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    /* Page title on the left, flex: 1 pushes the search box to the right */
    .topbar h1 { font-size: 14px; font-weight: 600; flex: 1; }

    /* Search input in the topbar */
    .topbar input {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 6px 12px;
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      outline: none;
      width: 200px;
    }

    /* Highlight border on focus for accessibility */
    .topbar input:focus { border-color: var(--accent); }
    .topbar input::placeholder { color: var(--muted); }

    /* Scrollable page body below the topbar */
    .content { padding: 28px; display: flex; flex-direction: column; gap: 20px; }


    /* ── STAT CARDS ─────────────────────────────────────────────────────────
       Four equal-width summary cards at the top of the dashboard */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

    .stat {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
    }

    /* Small uppercase label above the number (e.g. "Total Users") */
    .stat-label { font-size: 11px; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: .6px; margin-bottom: 8px; }

    /* Large monospaced number — monospace keeps digit widths consistent */
    .stat-value { font-family: 'IBM Plex Mono', monospace; font-size: 24px; font-weight: 500; }

    /* Trend line below the number */
    .stat-sub { font-size: 11.5px; color: var(--muted); margin-top: 4px; }
    .stat-sub.up { color: var(--success); }    /* Green for positive change */
    .stat-sub.down { color: var(--danger); }   /* Red for negative change */


    /* ── TWO-COLUMN GRID ────────────────────────────────────────────────────
       Left column: reports/logs panel. Right column: credits + quick actions */
    .grid { display: grid; grid-template-columns: 1fr 300px; gap: 16px; }


    /* ── CARD ───────────────────────────────────────────────────────────────
       Reusable white bordered container used for the main panels */
    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;   /* Clip child content to rounded corners */
    }

    /* Card title row with optional right-aligned subtitle */
    .card-head {
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .card-head h2 { font-size: 13px; font-weight: 600; }
    .card-head .sub { font-size: 11.5px; color: var(--muted); }


    /* ── TABS ───────────────────────────────────────────────────────────────
       Toggle between "Reports" and "Security Logs" inside the left card.
       The active tab has a blue underline border. */
    .tabs { display: flex; border-bottom: 1px solid var(--border); }

    .tab {
      padding: 12px 20px;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;   /* Overlap the card border so active border sits on top */
      transition: color .1s, border-color .1s;
    }

    .tab:hover { color: var(--text); }
    .tab.active { color: var(--accent); border-color: var(--accent); }


    /* ── REPORTS TABLE ──────────────────────────────────────────────────────
       Full-width table listing user reports, sorted oldest to newest (FR23) */
    table { width: 100%; border-collapse: collapse; }

    thead th {
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .7px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 10px 20px;
      border-bottom: 1px solid var(--border);
    }

    /* Each row is clickable — opens the report detail modal */
    tbody tr { border-bottom: 1px solid var(--border); transition: background .1s; cursor: pointer; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--bg); }
    tbody td { padding: 12px 20px; font-size: 13px; vertical-align: middle; }


    /* ── STATUS PILLS ───────────────────────────────────────────────────────
       Colour-coded badges showing report status (New / Ongoing / Resolved) */
    .pill {
      display: inline-block;
      font-size: 11px;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: 99px;
    }

    .pill-new      { background: #dbeafe; color: #1d4ed8; }   /* Blue */
    .pill-ongoing  { background: #fef3c7; color: #92400e; }   /* Amber */
    .pill-resolved { background: #dcfce7; color: #15803d; }   /* Green */


    /* ── ACTION BUTTONS ─────────────────────────────────────────────────────
       Inline row of small buttons within each table row */
    .btn-row { display: flex; gap: 6px; }

    /* Base button style — all variants build on this */
    .btn {
      display: inline-block;
      padding: 5px 12px;
      border-radius: var(--radius);
      font-family: inherit;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text);
      transition: opacity .1s;
    }

    .btn:hover { opacity: .7; }

    /* Coloured button variants */
    .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
    .btn-danger  { background: #fee2e2; color: var(--danger); border-color: #fecaca; }
    .btn-warn    { background: #fef3c7; color: var(--warn);   border-color: #fde68a; }
    .btn-success { background: #dcfce7; color: var(--success); border-color: #bbf7d0; }


    /* ── CREDIT METRICS ─────────────────────────────────────────────────────
       Stack of labelled values inside the right-hand Credits card (NFR6) */
    .metric {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }

    .metric:last-child { border-bottom: none; }

    .metric-label { font-size: 11px; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: .6px; margin-bottom: 6px; }
    .metric-value { font-family: 'IBM Plex Mono', monospace; font-size: 20px; font-weight: 500; }
    .metric-sub   { font-size: 12px; color: var(--muted); margin-top: 2px; }

    /* Stacked full-width buttons in the Quick Actions card */
    .quick-actions { display: flex; flex-direction: column; gap: 6px; padding: 14px; }


    /* ── SECURITY LOG ROWS ──────────────────────────────────────────────────
       Three-column grid: coloured dot | log message | timestamp + severity.
       Displayed when the "Security Logs" tab is active (FR24) */
    .log-row {
      display: grid;
      grid-template-columns: 10px 1fr auto;
      gap: 12px;
      align-items: start;
      padding: 11px 20px;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }

    .log-row:last-child { border-bottom: none; }

    /* Small coloured dot indicating log severity at a glance */
    .log-dot { width: 7px; height: 7px; border-radius: 50%; margin-top: 5px; }
    .dot-error { background: var(--danger); }   /* Red  — high severity */
    .dot-warn  { background: var(--warn);   }   /* Amber — medium severity */
    .dot-ok    { background: var(--success);}   /* Green — resolved / admin action */
    .dot-info  { background: var(--accent); }   /* Blue  — informational */

    /* Secondary detail line within a log entry (e.g. username or endpoint) */
    .log-msg small { color: var(--muted); display: block; font-size: 12px; }

    /* Monospaced timestamp to keep columns aligned */
    .log-ts { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--muted); white-space: nowrap; margin-top: 3px; }

    /* Severity text labels — colour matches the dot */
    .sev { font-size: 11px; }
    .sev-high { color: var(--danger); }
    .sev-med  { color: var(--warn);   }
    .sev-none { color: var(--muted);  }


    /* ── REPORT DETAIL MODAL ────────────────────────────────────────────────
       Shown when an admin clicks a report row.
       Overlay covers the whole screen; clicking outside closes the modal. */
    .overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.25);   /* Semi-transparent backdrop */
      display: none;                  /* Hidden by default */
      align-items: center;
      justify-content: center;
      z-index: 100;
      padding: 20px;
    }

    /* JS adds this class to show the modal */
    .overlay.show { display: flex; }

    /* Modal panel — white card centred in the overlay */
    .modal {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      width: 100%;
      max-width: 460px;
    }

    /* Modal title bar with close button */
    .modal-head {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .modal-head h3 { font-size: 14px; font-weight: 600; }

    /* Plain × close button */
    .close-btn { background: none; border: none; color: var(--muted); font-size: 18px; cursor: pointer; }
    .close-btn:hover { color: var(--text); }

    /* Modal body holds the report message and metadata chips */
    .modal-body { padding: 20px; display: flex; flex-direction: column; gap: 14px; }

    /* Small uppercase field labels inside the modal */
    .field-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); margin-bottom: 4px; }

    /* Read-only display box for the report message text */
    .field-value {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 12px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.55;
    }

    /* Wrapping row of metadata chips (reporter, reported, filed, status) */
    .chips { display: flex; gap: 8px; flex-wrap: wrap; }

    /* Individual metadata chip */
    .chip {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 4px 10px;
      font-size: 12px;
    }

    /* Muted key prefix inside each chip (e.g. "Reporter ") */
    .chip b { color: var(--muted); font-weight: 400; margin-right: 4px; }

    /* Modal footer with action buttons (Ban, Set Ongoing, Resolve, Cancel) */
    .modal-foot {
      padding: 14px 20px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 6px;
      justify-content: flex-end;
    }


    /* ── RESPONSIVE BREAKPOINTS ─────────────────────────────────────────────
       Reflow layout for smaller screens */
    @media (max-width: 900px) {
      /* Stack stat cards into two columns on medium screens */
      .stats { grid-template-columns: 1fr 1fr; }
      /* Stack main grid into a single column on medium screens */
      .grid  { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<div class="layout">

  <!-- ══ SIDEBAR ══════════════════════════════════════════════════════════
       Fixed left navigation. "active" class marks the current page.
       Report count badge is hardcoded here — wire to backend in production. -->
  <aside class="sidebar">
    <div class="logo">
      TradeSkills
      <span>Admin Portal</span>
    </div>

    <nav>
      <!-- Main section -->
      <div class="section-label">Main</div>
      <a href="#" class="active">Dashboard</a>

      <!-- Moderation section — Reports links to the reports tab via JS -->
      <div class="section-label">Moderation</div>
      <a href="#" onclick="switchTab('reports');return false">Reports <span class="badge">7</span></a>
      <a href="#" onclick="switchTab('logs');return false">Security Logs</a>

      <!-- Platform management links (to be wired to their own pages) -->
      <div class="section-label">Platform</div>
      <a href="#">Users</a>
      <a href="#">Credits</a>
      <a href="#">Lessons</a>

      <!-- Account management -->
      <div class="section-label">Account</div>
      <a href="#">Settings</a>
      <a href="#">Log out</a>
    </nav>

    <!-- Logged-in admin identity shown at the bottom of the sidebar -->
    <div class="sidebar-footer">
      <strong>Admin</strong>
      Administrator
    </div>
  </aside>


  <!-- ══ MAIN CONTENT ══════════════════════════════════════════════════════ -->
  <div class="main">

    <!-- Page title bar with global search input -->
    <div class="topbar">
      <h1>Dashboard</h1>
      <input type="text" placeholder="Search users, reports…"/>
    </div>

    <div class="content">

      <!-- ── STAT CARDS ──────────────────────────────────────────────────
           Four KPI tiles giving the admin an at-a-glance platform summary.
           Values are static here — replace with template variables in Flask. -->
      <div class="stats">

        <!-- Total registered user count -->
        <div class="stat">
          <div class="stat-label">Total Users</div>
          <div class="stat-value">1,284</div>
          <div class="stat-sub up">+32 this week</div>
        </div>

        <!-- Total credits currently held across all accounts (NFR6) -->
        <div class="stat">
          <div class="stat-label">Credits in Circulation</div>
          <div class="stat-value">48,320</div>
          <div class="stat-sub up">+1,140 this fortnight</div>
        </div>

        <!-- Unresolved user reports needing admin attention (FR23) -->
        <div class="stat">
          <div class="stat-label">Open Reports</div>
          <div class="stat-value">7</div>
          <div class="stat-sub down">+3 since yesterday</div>
        </div>

        <!-- Cumulative lessons completed across all users -->
        <div class="stat">
          <div class="stat-label">Lessons Completed</div>
          <div class="stat-value">3,091</div>
          <div class="stat-sub up">+84 this week</div>
        </div>

      </div>


      <!-- ── TWO-COLUMN GRID ─────────────────────────────────────────────
           Left: tabbed reports/logs panel. Right: credits overview + quick actions. -->
      <div class="grid">

        <!-- LEFT CARD: Reports & Security Logs tabs -->
        <div class="card">

          <!-- Tab bar — JS switchTab() shows/hides the corresponding view div -->
          <div class="tabs">
            <div class="tab active" id="tab-reports" onclick="switchTab('reports')">Reports</div>
            <div class="tab"        id="tab-logs"    onclick="switchTab('logs')">Security Logs</div>
          </div>


          <!-- ── REPORTS VIEW ──────────────────────────────────────────────
               Shown by default. Lists unresolved reports sorted oldest→newest (FR23).
               Clicking a row opens the detail modal.
               Buttons in each row use event.stopPropagation() to avoid triggering the row click. -->
          <div id="view-reports">
            <table>
              <thead>
                <tr>
                  <th>Reporter → Reported</th>
                  <th>Description</th>
                  <th>Status</th>
                  <th>Filed</th>
                  <th></th> <!-- Action buttons column — no heading needed -->
                </tr>
              </thead>
              <tbody>

                <!-- Report row: args to openModal are (description, reporter, reported, time, status) -->
                <tr onclick="openModal('Inappropriate messaging during lesson session.','jsmith','u_pete99','4 hrs ago','new')">
                  <td>jsmith → u_pete99</td>
                  <td style="color:var(--muted)">Inappropriate messaging during lesson</td>
                  <td><span class="pill pill-new">New</span></td>
                  <td style="color:var(--muted)">4 hrs ago</td>
                  <td>
                    <!-- stopPropagation prevents the row onclick firing when buttons are clicked -->
                    <div class="btn-row" onclick="event.stopPropagation()">
                      <button class="btn btn-warn">Ongoing</button>
                      <button class="btn btn-success">Resolve</button>
                    </div>
                  </td>
                </tr>

                <!-- This report is already Ongoing so only "Resolve" is shown -->
                <tr onclick="openModal('Fake review left — claims lesson never happened.','sarah_k','devguru','9 hrs ago','ongoing')">
                  <td>sarah_k → devguru</td>
                  <td style="color:var(--muted)">Fake review, lesson never happened</td>
                  <td><span class="pill pill-ongoing">Ongoing</span></td>
                  <td style="color:var(--muted)">9 hrs ago</td>
                  <td>
                    <div class="btn-row" onclick="event.stopPropagation()">
                      <button class="btn btn-success">Resolve</button>
                    </div>
                  </td>
                </tr>

                <tr onclick="openModal('Lesson content did not match the advertised description.','mike_b','skillshare99','1 day ago','new')">
                  <td>mike_b → skillshare99</td>
                  <td style="color:var(--muted)">Lesson didn't match description</td>
                  <td><span class="pill pill-new">New</span></td>
                  <td style="color:var(--muted)">1 day ago</td>
                  <td>
                    <div class="btn-row" onclick="event.stopPropagation()">
                      <button class="btn btn-warn">Ongoing</button>
                      <button class="btn btn-success">Resolve</button>
                    </div>
                  </td>
                </tr>

                <tr onclick="openModal('Abusive messages sent via chat after lesson was completed.','aiden_x','tutor_pro','2 days ago','new')">
                  <td>aiden_x → tutor_pro</td>
                  <td style="color:var(--muted)">Abusive messages after lesson</td>
                  <td><span class="pill pill-new">New</span></td>
                  <td style="color:var(--muted)">2 days ago</td>
                  <td>
                    <div class="btn-row" onclick="event.stopPropagation()">
                      <button class="btn btn-warn">Ongoing</button>
                      <button class="btn btn-success">Resolve</button>
                    </div>
                  </td>
                </tr>

              </tbody>
            </table>
          </div>


          <!-- ── SECURITY LOGS VIEW ────────────────────────────────────────
               Hidden by default; shown when "Security Logs" tab is clicked.
               Each row has a coloured dot, a message with detail, and a severity level (NFR7).
               In production these rows would be rendered by Flask from the database. -->
          <div id="view-logs" style="display:none">

            <!-- Red dot = high severity — account locked after 5 failed logins (NFR1) -->
            <div class="log-row">
              <div class="log-dot dot-error"></div>
              <div class="log-msg">Account locked after 5 failed logins<small>user: mark_d@email.com</small></div>
              <div><div class="log-ts">10:42 AM</div><div class="sev sev-high">High</div></div>
            </div>

            <!-- Green dot = admin action completed successfully -->
            <div class="log-row">
              <div class="log-dot dot-ok"></div>
              <div class="log-msg">Admin resolved report #312<small>by: admin@tradeskills.com</small></div>
              <div><div class="log-ts">10:31 AM</div><div class="sev sev-none">None</div></div>
            </div>

            <!-- Amber dot = medium severity — captcha triggered after 3 failures (NFR1) -->
            <div class="log-row">
              <div class="log-dot dot-warn"></div>
              <div class="log-msg">Captcha triggered after 3 failed logins<small>user: leo_test</small></div>
              <div><div class="log-ts">10:18 AM</div><div class="sev sev-med">Medium</div></div>
            </div>

            <!-- Admin deleted an account — logged as high severity admin action -->
            <div class="log-row">
              <div class="log-dot dot-ok"></div>
              <div class="log-msg">Admin deleted account<small>target: spam_bot_44</small></div>
              <div><div class="log-ts">09:55 AM</div><div class="sev sev-high">High</div></div>
            </div>

            <!-- Blue dot = informational — no threat, just a new registration -->
            <div class="log-row">
              <div class="log-dot dot-info"></div>
              <div class="log-msg">New user registered<small>user: priya.m@uni.ac.uk</small></div>
              <div><div class="log-ts">09:41 AM</div><div class="sev sev-none">None</div></div>
            </div>

            <!-- Admin removed credits from a user as a moderation action (FR29) -->
            <div class="log-row">
